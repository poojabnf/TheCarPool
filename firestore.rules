rules_version = '2';

// TheCarPool Firestore security rules.
//
// Design: all privileged data access goes through the backend gateway, which
// uses the Firebase Admin SDK and BYPASSES these rules. These rules therefore
// govern only direct client SDK access, and default to deny. We grant the
// narrowest client access that the apps actually need.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // Users may read and write only their own profile document.
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId);
      allow delete: if isAdmin();
    }

    // Per-user telemetry — owner read only; writes happen server-side.
    match /device_coordinates/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false; // backend (Admin SDK) only
    }

    // Rides & classifieds are publicly readable to signed-in users, but
    // mutations must go through the backend (which enforces ownership).
    match /rides/{rideId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /drivers/{driverId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /classifieds/{classifiedId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Bookings are sensitive — no direct client access; backend only.
    match /bookings/{bookingId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Reference data — read-only to signed-in clients.
    match /postal_codes/{doc} {
      allow read: if isSignedIn();
      allow write: if false;
    }
    match /countries/{doc} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Everything else: deny by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
