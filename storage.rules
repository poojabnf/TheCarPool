rules_version = '2';

// TheCarPool Firebase Storage security rules.
//
// KYC documents live under users/{uid}/kyc/** and must be readable/writable
// only by their owner. Uploads from the app use a signed URL minted by the
// backend, but these rules add defence-in-depth for any direct client access.
service firebase.storage {
  match /b/{bucket}/o {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Valid upload: image only, max 10 MB.
    function isValidImage() {
      return request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Per-user KYC documents — owner only, images up to 10 MB.
    match /users/{uid}/kyc/{allPaths=**} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isOwner(uid)
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Any other per-user assets — owner only, up to 10 MB.
    match /users/{uid}/{allPaths=**} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isOwner(uid)
        && request.resource.size < 10 * 1024 * 1024;
    }

    // Deny everything else by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
