{
  "name": "thecarpool-workspace",
  "version": "1.0.0",
  "description": "Unified workspace command runner for the TheCarPool platform",
  "private": true,
  "scripts": {
    "infra:up": "docker-compose up -d",
    "infra:down": "docker-compose down",
    "start:backend": "cd thecarpool-backend && npm run dev",
    "start:ai": "cd thecarpool-ai && python app/main.py",
    "start:mobile": "cd thecarpool-mobile && npm start"
  }
}
